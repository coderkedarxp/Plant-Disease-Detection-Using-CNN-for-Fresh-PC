########################################
# Data and Models (large, local-only)
########################################
# Raw/processed datasets
data/raw/
data/processed/

# Trained models and checkpoints (ignore by default)
models/saved_models/
models/checkpoints/

# Allow specific model folder by unignoring parent directories first
!models/
!models/saved_models/

# Keep essential metadata and selected model FIRST (before wildcards)
# Only the latest trained model will be included in the repo

# Latest model (30-epoch trained) - unignore specific folder and files
!models/saved_models/plant_disease_model2/
!models/saved_models/plant_disease_model2/class_indices.json
!models/saved_models/plant_disease_model2/training_config.json
!models/saved_models/plant_disease_model2/best_model.keras
!models/saved_models/plant_disease_model2/saved_model.pb
!models/saved_models/plant_disease_model2/assets/
!models/saved_models/plant_disease_model2/variables/

# Now ignore everything else in that folder
models/saved_models/plant_disease_model2/logs/
models/saved_models/plant_disease_model2/training_log.csv
models/saved_models/plant_disease_model2/final_model.keras

# Other model formats (after unignore rules)
*.h5
*.ckpt
*.pb
*.pth
*.pkl
*.onnx

# Training logs and TensorBoard
logs/
**/logs/**
events.out.tfevents*
*.log
**/training_log.csv

